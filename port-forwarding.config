# ChatApp - Port Forwarding Configuration
# Use this file to configure port forwarding for local development or tunneling

# ============ PORTS USED ============
# Backend API + Frontend:  5001 (Express + Socket.IO)
# MongoDB:                 27017 (default, if running locally)

# ============ NGROK (Expose to Internet) ============
# 1. Install: npm install -g ngrok
# 2. Run backend: npm run dev (in backend/)
# 3. Run: ngrok http 5001
# 4. Use the generated HTTPS URL (e.g. https://abc123.ngrok.io)

# Or create ngrok.yml in project root:
# version: "2"
# tunnels:
#   chat-app:
#     proto: http
#     addr: 5001
# Run: ngrok start chat-app

# ============ DOCKER PORT MAPPING ============
# If using Docker:
# docker run -p 5001:5001 chat-app
# -p 5001:5001 maps host port 5001 to container port 5001

# ============ SSH TUNNEL (Remote MongoDB) ============
# If MongoDB is on a remote server:
# ssh -L 27017:localhost:27017 user@remote-host

# ============ CODE-TUNNEL.EXE (VS Code Remote Tunnels) ============
# Path (Windows): C:\Users\<user>\AppData\Local\Programs\Microsoft VS Code\bin\code-tunnel.exe
# Or use: code tunnel (from VS Code integrated terminal)

# 1. Install: Install "Remote - Tunnels" extension in VS Code
# 2. Sign in: code tunnel login
# 3. Forward port 5001 for ChatApp:
#    - Open Command Palette (Ctrl+Shift+P) -> "Forward a Port"
#    - Enter: 5001
#    - Or run: code-tunnel.exe port forward 5001

# Add to PATH for easy access, or create shortcut:
# code-tunnel.exe tunnel --accept-server-license-terms

# ============ WINDOWS FIREWALL ============
# Allow inbound on port 5001:
# netsh advfirewall firewall add rule name="ChatApp" dir=in action=allow protocol=tcp localport=5001
